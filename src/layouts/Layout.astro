---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonical: string;
  lastReviewed?: string;
  schema?: string[];
  pageData?: Record<string, unknown>;
  breadcrumbs?: Array<{ name: string; url: string }>;
  faqItems?: Array<{ q: string; a: string }>;
}

const {
  title,
  description,
  canonical,
  lastReviewed,
  schema = [],
  pageData = {},
  breadcrumbs = [],
  faqItems = [],
} = Astro.props;

const SITE_NAME = 'FundingCompass';
const SITE_URL = 'https://fundingcompass.guide';

// Section-name → canonical absolute URL (used when pages pass url:'/' as a placeholder)
const SECTION_URLS: Record<string, string> = {
  'Guides':     `${SITE_URL}/guides/`,
  'Industries': `${SITE_URL}/industries/`,
  'Compare':    `${SITE_URL}/compare/`,
  'Providers':  `${SITE_URL}/providers/`,
  'Tools':      `${SITE_URL}/tools/`,
  'Glossary':   `${SITE_URL}/glossary/`,
};

/** Resolve a breadcrumb url value to an absolute URL. */
function resolveItem(name: string, url: string): string {
  if (url.startsWith('http')) return url;               // already absolute
  if (url === '/') return SECTION_URLS[name] ?? `${SITE_URL}/`;  // placeholder → section root
  return `${SITE_URL}${url}`;                           // relative path → absolute
}

/** Derive articleSection from the canonical URL path. */
function getArticleSection(url: string): string | null {
  const u = url.toLowerCase();
  if (u.includes('/guides/'))     return 'Guides';
  if (u.includes('/industries/')) return 'Industries';
  if (u.includes('/compare/'))    return 'Compare';
  if (u.includes('/providers/'))  return 'Provider Reviews';
  if (u.includes('/tools/'))      return 'Tools';
  if (u.includes('/glossary/'))   return 'Glossary';
  return null;
}

/** Derive topical keywords from the canonical URL for Article schema. */
function getKeywords(url: string): string {
  const base = 'B2B financing, small business funding, working capital';
  const u = url.toLowerCase();
  if (u.includes('invoice-factoring') || (u.includes('factoring') && !u.includes('purchase-order')))
    return `invoice factoring, accounts receivable financing, factoring company, ${base}`;
  if (u.includes('merchant-cash-advance') || u.includes('/mca-'))
    return `merchant cash advance, MCA, business cash advance, alternative financing, ${base}`;
  if (u.includes('equipment-leasing'))
    return `equipment leasing, operating lease, capital lease, equipment rental, ${base}`;
  if (u.includes('equipment-financ') || u.includes('equipment-loan'))
    return `equipment financing, equipment loans, business equipment, asset financing, ${base}`;
  if (u.includes('sba-loan') || u.includes('sba-504'))
    return `SBA loans, SBA 7(a), SBA 504, government-backed loans, ${base}`;
  if (u.includes('business-line-of-credit'))
    return `business line of credit, revolving credit facility, working capital line, ${base}`;
  if (u.includes('purchase-order'))
    return `purchase order financing, PO financing, supply chain financing, ${base}`;
  if (u.includes('accounts-receivable'))
    return `accounts receivable financing, AR financing, invoice financing, ${base}`;
  if (u.includes('trucking'))
    return `trucking factoring, freight factoring, carrier factoring, load factoring, ${base}`;
  if (u.includes('staffing'))
    return `staffing factoring, staffing agency financing, payroll financing, ${base}`;
  if (u.includes('healthcare'))
    return `healthcare factoring, medical factoring, medical billing financing, ${base}`;
  if (u.includes('construction'))
    return `construction factoring, contractor financing, construction working capital, ${base}`;
  if (u.includes('agricultural'))
    return `agricultural equipment financing, farm equipment loans, farm credit, ${base}`;
  if (u.includes('medical-equipment'))
    return `medical equipment financing, healthcare equipment loans, ${base}`;
  if (u.includes('restaurant'))
    return `restaurant equipment financing, restaurant financing, food service equipment, ${base}`;
  if (u.includes('retail'))
    return `retail factoring, retail supplier financing, purchase order factoring, ${base}`;
  if (u.includes('wholesale'))
    return `wholesale factoring, wholesale financing, distributor factoring, ${base}`;
  if (u.includes('government-contractor'))
    return `government contractor factoring, federal receivables financing, ${base}`;
  return base;
}

/** Derive FinancialProduct name + description from the canonical URL. */
function getFinancialProduct(url: string): { name: string; description: string } | null {
  const u = url.toLowerCase();
  if (u.includes('invoice-factoring') || (u.includes('factoring') && !u.includes('purchase-order')))
    return { name: 'Invoice Factoring',           description: 'A financing arrangement where businesses sell accounts receivable to a third party at a discount for immediate working capital.' };
  if (u.includes('equipment-leasing'))
    return { name: 'Equipment Leasing',           description: 'A rental arrangement allowing businesses to use equipment for a fixed term without purchasing it outright.' };
  if (u.includes('equipment-financing') || u.includes('equipment-loan'))
    return { name: 'Equipment Financing',         description: 'Loans or leases that enable businesses to acquire equipment, with the equipment typically serving as collateral.' };
  if (u.includes('merchant-cash-advance') || u.includes('mca-'))
    return { name: 'Merchant Cash Advance',       description: 'An advance against future sales repaid through a fixed percentage of daily credit card receipts.' };
  if (u.includes('sba-504') || u.includes('sba-loan') || u.includes('sba-loans'))
    return { name: 'SBA Loan',                    description: 'Government-guaranteed small business loans offered through SBA-approved lenders at below-market interest rates.' };
  if (u.includes('business-line-of-credit') || u.includes('line-of-credit'))
    return { name: 'Business Line of Credit',     description: 'A revolving credit facility allowing businesses to borrow up to a set limit and repay as needed.' };
  if (u.includes('purchase-order-financing'))
    return { name: 'Purchase Order Financing',    description: 'Short-term funding that covers supplier costs for confirmed purchase orders, enabling businesses to fulfil large orders.' };
  if (u.includes('accounts-receivable'))
    return { name: 'Accounts Receivable Financing', description: 'Asset-based borrowing using outstanding invoices as collateral to access immediate working capital.' };
  return null;
}

// Build JSON-LD blobs based on requested schema types
const jsonldBlocks: string[] = [];

// Organization + WebSite — homepage only
if (canonical === `${SITE_URL}/`) {
  jsonldBlocks.push(JSON.stringify([
    {
      '@context': 'https://schema.org',
      '@type': 'Organization',
      '@id': `${SITE_URL}/#organization`,
      name: SITE_NAME,
      url: SITE_URL,
      description: 'Independent editorial guide to specialty B2B financing. Verified rates, unbiased reviews, and comparison tools for invoice factoring, equipment financing, business lines of credit, merchant cash advances, and SBA loans.',
      email: 'hello@fundingcompass.guide',
      sameAs: [
        'https://www.linkedin.com/company/fundingcompass',
        'https://x.com/fundingcompass',
        'https://www.crunchbase.com/organization/funding-compass',
      ],
    },
    {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      '@id': `${SITE_URL}/#website`,
      name: SITE_NAME,
      url: SITE_URL,
      publisher: { '@id': `${SITE_URL}/#organization` },
      description: 'Independent. Accurate. Free. Research-driven guides to specialty B2B financing.',
      potentialAction: {
        '@type': 'SearchAction',
        target: `${SITE_URL}/?s={search_term_string}`,
        'query-input': 'required name=search_term_string',
      },
    },
  ], null, 0));
}

// BreadcrumbList — always include if we have crumbs
const allBreadcrumbs = [
  { name: 'Home', item: `${SITE_URL}/` },
  ...breadcrumbs.map(b => ({ name: b.name, item: resolveItem(b.name, b.url) })),
];
if (allBreadcrumbs.length > 1 || schema.includes('BreadcrumbList')) {
  jsonldBlocks.push(JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: allBreadcrumbs.map((b, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: b.name,
      item: b.item,
    })),
  }, null, 0));
}

// Article schema (with optional FinancialProduct typing)
if (schema.includes('Article')) {
  const financialProduct = getFinancialProduct(canonical);
  const articleSection    = getArticleSection(canonical);
  const keywords          = getKeywords(canonical);
  const pageImageUrl      = `https://fundingcompass.guide/apple-touch-icon.png`;

  const articleSchema: Record<string, unknown> = {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: title,
    description: description,
    // abstract = the article summary — used by AI engines to identify the
    // lead paragraph / key takeaways block as the authoritative summary.
    abstract: description,
    url: canonical,
    mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
    datePublished: lastReviewed ?? '2026-05-01',
    dateModified: lastReviewed ?? '2026-05-01',
    // Reference Person entity by @id — full definition emitted below
    author: { '@id': `${SITE_URL}/#author` },
    publisher: {
      '@type': 'Organization',
      '@id': `${SITE_URL}/#organization`,
      name: SITE_NAME,
      url: `${SITE_URL}/`,
    },
    // image — required for Google rich results; used by AI engines for
    // visual context when citing this page.
    image: {
      '@type': 'ImageObject',
      url: pageImageUrl,
      width: 180,
      height: 180,
    },
    // keywords — topical signals for classification.
    keywords: keywords,
    // speakable — tells AI engines (Google, voice assistants, LLM crawlers)
    // which CSS selectors contain the most citable / summarisable content.
    speakable: {
      '@type': 'SpeakableSpecification',
      cssSelector: ['h1', '[aria-label="Key takeaways"]', '.key-stat', '.related-resources__recap'],
    },
  };

  if (articleSection) articleSchema.articleSection = articleSection;

  if (financialProduct) {
    articleSchema.about = {
      '@type': 'FinancialProduct',
      name: financialProduct.name,
      description: financialProduct.description,
    };
  }
  jsonldBlocks.push(JSON.stringify(articleSchema, null, 0));

  // Person schema — emitted alongside every Article so AI engines see the
  // author entity on every crawled page; @id deduplicates across pages.
  jsonldBlocks.push(JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Person',
    '@id': `${SITE_URL}/#author`,
    name: 'David Mercer',
    jobTitle: 'Financial Writer',
    description: 'Independent financial writer specializing in B2B specialty financing, invoice factoring, and equipment lending. Over a decade of experience evaluating alternative lending products for small and mid-size businesses.',
    url: `${SITE_URL}/about/`,
    worksFor: { '@id': `${SITE_URL}/#organization` },
    knowsAbout: [
      { '@type': 'DefinedTerm', name: 'Invoice Factoring',        description: 'A financing method where businesses sell accounts receivable to a third party at a discount for immediate cash.',                              inDefinedTermSet: `${SITE_URL}/glossary/` },
      { '@type': 'DefinedTerm', name: 'Equipment Financing',      description: 'Loans or leases used to purchase business equipment, where the equipment itself serves as collateral.',                                       inDefinedTermSet: `${SITE_URL}/glossary/` },
      { '@type': 'DefinedTerm', name: 'Merchant Cash Advance',    description: 'A lump-sum payment to a business in exchange for a percentage of future credit card sales.',                                                  inDefinedTermSet: `${SITE_URL}/glossary/` },
      { '@type': 'DefinedTerm', name: 'SBA Loans',                description: 'Government-backed loans administered by the Small Business Administration with favorable terms for qualifying businesses.',                  inDefinedTermSet: `${SITE_URL}/glossary/` },
      { '@type': 'DefinedTerm', name: 'Business Line of Credit',  description: 'A revolving credit facility that allows businesses to draw funds up to a set limit and pay interest only on the amount used.',              inDefinedTermSet: `${SITE_URL}/glossary/` },
    ],
  }, null, 0));
}

// WebApplication schema — for interactive calculator/tool pages
if (schema.includes('WebApplication')) {
  jsonldBlocks.push(JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: title,
    url: canonical,
    description: description,
    applicationCategory: 'FinanceApplication',
    operatingSystem: 'Web',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
    },
    publisher: {
      '@type': 'Organization',
      name: SITE_NAME,
      url: `${SITE_URL}/`,
    },
  }, null, 0));
}

// FAQPage schema — built from faqItems prop
if (schema.includes('FAQPage') && faqItems.length > 0) {
  jsonldBlocks.push(JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map(item => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.a,
      },
    })),
  }, null, 0));
}

const pageTitle = `${title} | ${SITE_NAME}`;
