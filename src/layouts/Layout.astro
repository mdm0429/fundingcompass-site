---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonical: string;
  lastReviewed?: string;
  schema?: string[];
  pageData?: Record<string, unknown>;
  breadcrumbs?: Array<{ name: string; url: string }>;
  faqItems?: Array<{ q: string; a: string }>;
}

const {
  title,
  description,
  canonical,
  lastReviewed,
  schema = [],
  pageData = {},
  breadcrumbs = [],
  faqItems = [],
} = Astro.props;

const SITE_NAME = 'FundingCompass';
const SITE_URL = 'https://fundingcompass.guide';

// Section-name → canonical absolute URL (used when pages pass url:'/' as a placeholder)
const SECTION_URLS: Record<string, string> = {
  'Guides':     `${SITE_URL}/guides/`,
  'Industries': `${SITE_URL}/industries/`,
  'Compare':    `${SITE_URL}/compare/`,
  'Providers':  `${SITE_URL}/providers/`,
  'Tools':      `${SITE_URL}/tools/`,
  'Glossary':   `${SITE_URL}/glossary/`,
};

/** Resolve a breadcrumb url value to an absolute URL. */
function resolveItem(name: string, url: string): string {
  if (url.startsWith('http')) return url;               // already absolute
  if (url === '/') return SECTION_URLS[name] ?? `${SITE_URL}/`;  // placeholder → section root
  return `${SITE_URL}${url}`;                           // relative path → absolute
}

// Build JSON-LD blobs based on requested schema types
const jsonldBlocks: string[] = [];

// BreadcrumbList — always include if we have crumbs
const allBreadcrumbs = [
  { name: 'Home', item: `${SITE_URL}/` },
  ...breadcrumbs.map(b => ({ name: b.name, item: resolveItem(b.name, b.url) })),
];
if (allBreadcrumbs.length > 1 || schema.includes('BreadcrumbList')) {
  jsonldBlocks.push(JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: allBreadcrumbs.map((b, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: b.name,
      item: b.item,
    })),
  }, null, 0));
}

// Article schema
if (schema.includes('Article')) {
  jsonldBlocks.push(JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: title,
    description: description,
    url: canonical,
    mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
    datePublished: lastReviewed ?? '2026-05-01',
    dateModified: lastReviewed ?? '2026-05-01',
    publisher: {
      '@type': 'Organization',
      name: SITE_NAME,
      url: `${SITE_URL}/`,
    },
    author: {
      '@type': 'Organization',
      name: `${SITE_NAME} Editorial Team`,
    },
  }, null, 0));
}

// WebApplication schema — for interactive calculator/tool pages
if (schema.includes('WebApplication')) {
  jsonldBlocks.push(JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: title,
    url: canonical,
    description: description,
    applicationCategory: 'FinanceApplication',
    operatingSystem: 'Web',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
    },
    publisher: {
      '@type': 'Organization',
      name: SITE_NAME,
      url: `${SITE_URL}/`,
    },
  }, null, 0));
}

// FAQPage schema — built from faqItems prop
if (schema.includes('FAQPage') && faqItems.length > 0) {
  jsonldBlocks.push(JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map(item => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.a,
      },
    })),
  }, null, 0));
}

const pageTitle = `${title} | ${SITE_NAME}`;
