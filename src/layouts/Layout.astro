    <script is:inline>
    (function () {
      /* ── Dropdown nav ─────────────────────────────────────────────────────────
         Strategy:
         - JS owns all open/close state via .is-open on the <li>; CSS :hover is
           not used for dropdowns (it was breaking sticky on arrow transform).
         - mouseenter on the <li> opens immediately and cancels any pending close.
         - mouseleave on the <li> starts a 150 ms timer — gives the cursor time to
           cross the 4 px gap and reach the panel before we close anything.
         - mouseenter on the panel itself also cancels the timer (belt + braces).
         - Click on the trigger toggles (useful for touch / keyboard users).
         - Escape and outside-click close everything.
      ──────────────────────────────────────────────────────────────────────── */
      var items  = [].slice.call(document.querySelectorAll('.site-nav__item--has-sub'));
      var timers = [];

      function openItem(item) {
        var idx = items.indexOf(item);
        clearTimeout(timers[idx]);
        // Close siblings
        items.forEach(function (i, j) { if (i !== item) closeItem(i, j); });
        item.classList.add('is-open');
        item.querySelector('.site-nav__trigger').setAttribute('aria-expanded', 'true');
      }

      function closeItem(item, idx) {
        if (idx === undefined) idx = items.indexOf(item);
        clearTimeout(timers[idx]);
        item.classList.remove('is-open');
        item.querySelector('.site-nav__trigger').setAttribute('aria-expanded', 'false');
      }

      function closeAll() { items.forEach(closeItem); }

      items.forEach(function (item, idx) {
        var trigger = item.querySelector('.site-nav__trigger');
        var panel   = item.querySelector('.site-nav__sub');

        // Hover — open on enter, delayed close on leave
        item.addEventListener('mouseenter', function () { openItem(item); });
        item.addEventListener('mouseleave', function () {
          timers[idx] = setTimeout(function () { closeItem(item, idx); }, 150);
        });

        // Belt-and-braces: re-cancel close timer when cursor enters the panel
        if (panel) {
          panel.addEventListener('mouseenter', function () {
            clearTimeout(timers[idx]);
          });
        }

        // Click / keyboard toggle
        trigger.addEventListener('click', function (e) {
          e.stopPropagation();
          item.classList.contains('is-open') ? closeItem(item, idx) : openItem(item);
        });
      });

      // Outside click closes everything
      document.addEventListener('click', closeAll);

      // Escape closes everything
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeAll();
      });

      /* ── Mobile burger ──────────────────────────────────────────────────── */
      var burger = document.getElementById('nav-burger');
      if (burger) {
        burger.addEventListener('click', function () {
          var expanded = this.getAttribute('aria-expanded') === 'true';
          this.setAttribute('aria-expanded', String(!expanded));
          this.closest('.site-header').classList.toggle('nav-open');
        });
      }
    })();
    </script>

